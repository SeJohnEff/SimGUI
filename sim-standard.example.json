{
  "$schema": "sim-standard-v1",
  "version": 1,
  "document": {
    "title": "Teleaura SIM & PLMN Numbering Standard",
    "revision": "2.2",
    "date": "2026-03-17",
    "scope": "Teleaura UK and all sub-networks",
    "classification": "Confidential"
  },

  "plmns": {
    "99988": {
      "mcc": "999",
      "mnc": "88",
      "mnc_length": 2,
      "purpose": "Teleaura Production Networks",
      "issuer_id": "88",
      "iin": "8999988",
      "status": "active"
    },
    "99989": {
      "mcc": "999",
      "mnc": "89",
      "mnc_length": 2,
      "purpose": "Teleaura Lab / Test Networks",
      "issuer_id": "89",
      "iin": "8999989",
      "status": "active"
    }
  },

  "default_plmn": "99988",

  "sites": {
    "0001": {
      "code": "uk1",
      "country": "United Kingdom",
      "country_code_e164": "44",
      "description": "Primary UK data centre / lab",
      "status": "active"
    },
    "0002": {
      "code": "se1",
      "country": "Sweden",
      "country_code_e164": "46",
      "description": "Primary Sweden data centre",
      "status": "active"
    },
    "0003": {
      "code": "se2",
      "country": "Sweden",
      "country_code_e164": "46",
      "description": "Sweden DR site",
      "status": "active"
    },
    "0004": {
      "code": "au1",
      "country": "Australia",
      "country_code_e164": "61",
      "description": "Primary Australia site",
      "status": "reserved"
    }
  },

  "sim_types": {
    "0": {"name": "USIM",      "description": "Standard physical SIM (2FF/3FF/4FF)"},
    "1": {"name": "USIM+SUCI", "description": "5G SUCI privacy SIM (SYSMOCOM-sourced)"},
    "2": {"name": "eSIM",      "description": "eUICC remote provisioning (MFF2)"},
    "9": {"name": "Test/Dev",  "description": "Lab and development cards"}
  },

  "fplmn_by_country": {
    "United Kingdom": ["23415", "23410", "23420", "23430"],
    "Sweden":         ["24007", "24024", "24001", "24008", "24002"]
  },

  "sim_profile_defaults": {
    "li": "EN",
    "hplmn": "99988",
    "ehplmn": ["99988", "99989"],
    "spn": "",
    "algo_2g": "MILENAGE",
    "algo_3g": "MILENAGE",
    "algo_4g5g": "MILENAGE",
    "use_opc": true,
    "adm1_empty_cards": "3838383838383838"
  },

  "numbering": {
    "imsi": {
      "format": "MCC(3) + MNC(2) + SSSS(4) + T(1) + NNNNN(5)",
      "length": 15,
      "fields": {
        "mcc": {"digits": 3, "description": "Mobile Country Code"},
        "mnc": {"digits": 2, "description": "Mobile Network Code"},
        "site": {"digits": 4, "description": "Site ID (SSSS)"},
        "sim_type": {"digits": 1, "description": "SIM type (T)"},
        "sequence": {"digits": 5, "description": "Sequence number (NNNNN)"}
      },
      "msin_length_2digit_mnc": 10,
      "msin_length_3digit_mnc": 9,
      "max_sequence_2digit_mnc": 99999,
      "max_sequence_3digit_mnc": 9999
    },
    "iccid": {
      "format": "89(2) + CCC(3) + II(2) + SSSS(4) + T(1) + NNNNNN(6) + L(1)",
      "length": 19,
      "conforms_to": "ITU-T E.118 (max 19 visible characters)",
      "fields": {
        "mii": {"digits": 2, "value": "89", "description": "Major Industry Identifier (telecom)"},
        "country_code": {"digits": 3, "value": "999", "description": "E.164 country code (test/private)"},
        "issuer": {"digits": 2, "description": "Issuer identifier (= MNC)"},
        "site": {"digits": 4, "description": "Site ID (SSSS), same as IMSI"},
        "sim_type": {"digits": 1, "description": "SIM type (T), same as IMSI"},
        "sequence": {"digits": 6, "description": "Sequence number (NNNNNN)"},
        "luhn": {"digits": 1, "description": "Luhn check digit"}
      },
      "max_sequence": 999999,
      "note": "All card types use 19-digit ICCID. IIN (7 digits) = 89 + CCC + II. Site, type, and sequence mirror IMSI structure but ICCID sequence is 6 digits (vs 5 in IMSI) due to Luhn overhead."
    }
  },

  "key_generation": {
    "method": "random",
    "ki_bits": 128,
    "opc_bits": 128,
    "note": "Ki and OPc are generated as cryptographically random 128-bit values. Future option: derive OPc from a master OP key using MILENAGE. Review this decision when deploying to production HSS/UDM."
  },

  "spn_values": ["BOLIDEN", "TELEAURA", "FISKARHEDEN"],
  "li_values": ["EN", "SV", "FI"],

  "allocations": {
    "uk1": [
      {"site_id": "0001", "sim_type": "0", "customer": "Boliden (USIM)",      "range_start": 1,   "range_end": 19,  "notes": "Enterprise, Aitik Mine"},
      {"site_id": "0001", "sim_type": "1", "customer": "Boliden (SUCI)",      "range_start": 1,   "range_end": 9,   "notes": "SUCI-enabled SIMs"},
      {"site_id": "0001", "sim_type": "0", "customer": "Teleaura Internal",   "range_start": 100, "range_end": 109, "notes": "Infrastructure SIMs"},
      {"site_id": "0001", "sim_type": "9", "customer": "Demo Pool",           "range_start": 1,   "range_end": 9,   "notes": "Trade shows, PoCs"}
    ],
    "se1": [
      {"site_id": "0002", "sim_type": "0", "customer": "Boliden (legacy)",    "range_start": 1,   "range_end": 9,   "notes": "Original 99988 SIMs"},
      {"site_id": "0002", "sim_type": "0", "customer": "Teleaura Internal",   "range_start": 100, "range_end": 109, "notes": "Infrastructure SIMs"}
    ]
  }
}
